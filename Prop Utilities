import maya.cmds as cmds
 
 
def create_cylinder(radius, height, name):
    """Create a basic cylinder with a given radius, height, and name.
 
    Args:
        radius (float): The radius of the cylinder.
        height (float): The total height of the cylinder.
        name (str): The name of the object in the Maya outliner.
 
    Returns:
        str: The name of the created cylinder transform node.
 
    Raises:
        ValueError: If radius or height are not positive numbers.
    """
    if radius <= 0:
        raise ValueError(f"Cylinder radius must be positive, got {radius}")
    if height <= 0:
        raise ValueError(f"Cylinder height must be positive, got {height}")
 
    cyl = cmds.polyCylinder(
        radius=radius,
        height=height,
        subdivisionsX=12,
        name=name
    )[0]
    return cyl
 
 
def create_leg(height, radius=0.04, position=(0, 0, 0)):
    """Create a single thin cylindrical leg for benches or racks.
 
    Args:
        height (float): How tall the leg should be.
        radius (float): How thick the leg is. Default 0.04.
        position (tuple): (x, y, z) where the base of the leg sits.
 
    Returns:
        str: The name of the created leg transform node.
    """
    leg = create_cylinder(radius=radius, height=height, name="leg_#")
    cmds.move(
        position[0],
        position[1] + height / 2.0,
        position[2],
        leg
    )
    return leg
 
 
def create_dumbbell(handle_length=0.4, head_radius=0.15, position=(0, 0, 0)):
    """Create a dumbbell: a short handle cylinder with a sphere on each end.
 
    Args:
        handle_length (float): Length of the middle grip bar. Default 0.4.
        head_radius (float): Radius of the weight spheres. Default 0.15.
        position (tuple): (x, y, z) center position. Default origin.
 
    Returns:
        str: Name of the dumbbell group node.
 
    Raises:
        ValueError: If handle_length or head_radius are not positive.
    """
    if handle_length <= 0:
        raise ValueError(f"handle_length must be positive, got {handle_length}")
    if head_radius <= 0:
        raise ValueError(f"head_radius must be positive, got {head_radius}")
 
    handle_radius = 0.04
 
    handle = create_cylinder(
        radius=handle_radius,
        height=handle_length,
        name="dumbbell_handle_#"
    )
    cmds.rotate(0, 0, 90, handle)
 
    left_head = cmds.polySphere(radius=head_radius, name="dumbbell_head_L_#")[0]
    cmds.move(-(handle_length / 2.0 + head_radius * 0.5), 0, 0, left_head)
 
    right_head = cmds.polySphere(radius=head_radius, name="dumbbell_head_R_#")[0]
    cmds.move((handle_length / 2.0 + head_radius * 0.5), 0, 0, right_head)
 
    dumbbell_grp = cmds.group(handle, left_head, right_head, name="dumbbell_#")
    cmds.move(position[0], position[1], position[2], dumbbell_grp)
 
    return dumbbell_grp
 
 
def create_barbell(bar_length=1.8, plate_count=2, plate_radius=0.35, position=(0, 0, 0)):
    """Create a barbell: a long bar with stacked plates on each end.
 
    Args:
        bar_length (float): Total length of the bar. Default 1.8.
        plate_count (int): Number of plates on each side. Default 2.
        plate_radius (float): Radius of each plate. Default 0.35.
        position (tuple): (x, y, z) center position. Default origin.
 
    Returns:
        str: Name of the barbell group node.
 
    Raises:
        ValueError: If any dimension is invalid.
    """
    if bar_length <= 0:
        raise ValueError(f"bar_length must be positive, got {bar_length}")
    if plate_count < 1:
        raise ValueError(f"plate_count must be at least 1, got {plate_count}")
    if plate_radius <= 0:
        raise ValueError(f"plate_radius must be positive, got {plate_radius}")
 
    bar_radius = 0.025
    plate_thickness = 0.05
    parts = []
 
    bar = create_cylinder(radius=bar_radius, height=bar_length, name="barbell_bar_#")
    cmds.rotate(0, 0, 90, bar)
    parts.append(bar)
 
    for i in range(plate_count):
        plate = create_cylinder(
            radius=plate_radius,
            height=plate_thickness,
            name="barbell_plate_L_#"
        )
        cmds.rotate(0, 0, 90, plate)
        x_offset = -(bar_length / 2.0 - 0.1) - (i * (plate_thickness + 0.01))
        cmds.move(x_offset, 0, 0, plate)
        parts.append(plate)
 
    for i in range(plate_count):
        plate = create_cylinder(
            radius=plate_radius,
            height=plate_thickness,
            name="barbell_plate_R_#"
        )
        cmds.rotate(0, 0, 90, plate)
        x_offset = (bar_length / 2.0 - 0.1) + (i * (plate_thickness + 0.01))
        cmds.move(x_offset, 0, 0, plate)
        parts.append(plate)
 
    barbell_grp = cmds.group(*parts, name="barbell_#")
    cmds.move(position[0], position[1], position[2], barbell_grp)
 
    return barbell_grp
 
 
def create_bench(seat_width=0.5, seat_length=1.2, leg_height=0.4, position=(0, 0, 0)):
    """Create a weight bench: a flat seat pad on 4 legs.
 
    Args:
        seat_width (float): Width of the seat. Default 0.5.
        seat_length (float): Length of the seat. Default 1.2.
        leg_height (float): Height of the legs. Default 0.4.
        position (tuple): (x, y, z) base center. Default origin.
 
    Returns:
        str: Name of the bench group node.
 
    Raises:
        ValueError: If any dimension is not positive.
    """
    if seat_width <= 0:
        raise ValueError(f"seat_width must be positive, got {seat_width}")
    if seat_length <= 0:
        raise ValueError(f"seat_length must be positive, got {seat_length}")
    if leg_height <= 0:
        raise ValueError(f"leg_height must be positive, got {leg_height}")
 
    seat_thickness = 0.08
    parts = []
 
    seat = cmds.polyCube(
        width=seat_length,
        height=seat_thickness,
        depth=seat_width,
        name="bench_seat_#"
    )[0]
    cmds.move(0, leg_height + seat_thickness / 2.0, 0, seat)
    parts.append(seat)
 
    x_offset = seat_length / 2.0 - 0.08
    z_offset = seat_width / 2.0 - 0.06
 
    corner_positions = [
        (x_offset, 0, z_offset),
        (x_offset, 0, -z_offset),
        (-x_offset, 0, z_offset),
        (-x_offset, 0, -z_offset),
    ]
 
    for pos in corner_positions:
        leg = create_leg(height=leg_height, position=pos)
        parts.append(leg)
 
    bench_grp = cmds.group(*parts, name="bench_#")
    cmds.move(position[0], position[1], position[2], bench_grp)
 
    return bench_grp
 
 
def create_squat_rack(height=2.2, width=1.2, position=(0, 0, 0)):
    """Create a squat rack: two uprights with pegs and a crossbar.
 
    Args:
        height (float): Height of the uprights. Default 2.2.
        width (float): Distance between uprights. Default 1.2.
        position (tuple): (x, y, z) base center. Default origin.
 
    Returns:
        str: Name of the squat rack group node.
 
    Raises:
        ValueError: If height or width are not positive.
    """
    if height <= 0:
        raise ValueError(f"height must be positive, got {height}")
    if width <= 0:
        raise ValueError(f"width must be positive, got {width}")
 
    upright_radius = 0.05
    peg_radius = 0.03
    peg_length = 0.2
    peg_height = height * 0.7
    parts = []
 
    left_upright = create_cylinder(
        radius=upright_radius,
        height=height,
        name="rack_upright_L_#"
    )
    cmds.move(-width / 2.0, height / 2.0, 0, left_upright)
    parts.append(left_upright)
 
    right_upright = create_cylinder(
        radius=upright_radius,
        height=height,
        name="rack_upright_R_#"
    )
    cmds.move(width / 2.0, height / 2.0, 0, right_upright)
    parts.append(right_upright)
 
    left_peg = create_cylinder(
        radius=peg_radius,
        height=peg_length,
        name="rack_peg_L_#"
    )
    cmds.rotate(0, 0, 90, left_peg)
    cmds.move(-width / 2.0 + peg_length / 2.0, peg_height, 0, left_peg)
    parts.append(left_peg)
 
    right_peg = create_cylinder(
        radius=peg_radius,
        height=peg_length,
        name="rack_peg_R_#"
    )
    cmds.rotate(0, 0, 90, right_peg)
    cmds.move(width / 2.0 - peg_length / 2.0, peg_height, 0, right_peg)
    parts.append(right_peg)
 
    crossbar = create_cylinder(
        radius=peg_radius,
        height=width,
        name="rack_crossbar_#"
    )
    cmds.rotate(0, 0, 90, crossbar)
    cmds.move(0, height - 0.1, 0, crossbar)
    parts.append(crossbar)
 
    rack_grp = cmds.group(*parts, name="squat_rack_#")
    cmds.move(position[0], position[1], position[2], rack_grp)
 
    return rack_grp
 
