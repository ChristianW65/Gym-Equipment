import maya.cmds as cmds


def create_material(name, color=(0.5, 0.5, 0.5)):
    """Create a Lambert shader with a given name and RGB color.

    Args:
        name (str): Name of the shader in the Hypershade.
        color (tuple): (R, G, B) values between 0.0 and 1.0.

    Returns:
        str: The name of the created Lambert shader node.

    Raises:
        ValueError: If color values are outside the 0.0-1.0 range.
    """
    if not all(0.0 <= c <= 1.0 for c in color):
        raise ValueError(f"Color values must be between 0.0 and 1.0, got {color}")

    shader = cmds.shadingNode("lambert", asShader=True, name=name)
    cmds.setAttr(
        shader + ".color",
        color[0], color[1], color[2],
        type="double3"
    )
    return shader


def assign_material(obj_name, shader_name):
    """Assign an existing shader to a Maya object.

    Args:
        obj_name (str): The Maya object to apply the material to.
        shader_name (str): The shader node to apply.

    Returns:
        None

    Raises:
        RuntimeError: If the object or shader does not exist in the scene.
    """
    if not cmds.objExists(obj_name):
        raise RuntimeError(f"Object '{obj_name}' does not exist in the scene.")
    if not cmds.objExists(shader_name):
        raise RuntimeError(f"Shader '{shader_name}' does not exist in the scene.")

    shading_group = cmds.sets(
        renderable=True,
        noSurfaceShader=True,
        empty=True,
        name=shader_name + "_SG"
    )
    cmds.connectAttr(
        shader_name + ".outColor",
        shading_group + ".surfaceShader",
        force=True
    )
    cmds.sets(obj_name, edit=True, forceElement=shading_group)
